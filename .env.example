# ── Required (at least one) ──────────────────────────────────────────────────

# Direct Anthropic key — enables Claude Code harness
ANTHROPIC_API_KEY=

# Direct OpenAI key — enables Codex harness
OPENAI_API_KEY=

# Vercel AI Gateway key — single key covering both harnesses
# VERCEL_AI_GATEWAY_API_KEY=

# ── Optional overrides ───────────────────────────────────────────────────────

# Override default Claude model (default: claude-sonnet-4-6)
# CLAUDE_CODE_MODEL=claude-sonnet-4-6

# Override default Codex model (default: o4-mini)
# CODEX_MODEL=o4-mini

# Skip specific harnesses in CLI mode
# SKIP_CLAUDE_CODE=1
# SKIP_CODEX=1

# Custom bridge port for harness communication
# HARNESS_BRIDGE_PORT=41987
